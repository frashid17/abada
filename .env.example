# Local development only — see .env.production.example for Vercel / production values.

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Clerk routes (required — proxy.ts reads these at runtime for optimistic redirects)
# Clerk routes — ABSOLUTE URLs required in dev (relative paths send users to accounts.dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=http://localhost:3000/iniciar-sesion
NEXT_PUBLIC_CLERK_SIGN_UP_URL=http://localhost:3000/registro
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=http://localhost:3000/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=http://localhost:3000/onboarding
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=http://localhost:3000/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=http://localhost:3000/onboarding

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Brand config (never hardcode in components — use i18n + env)
NEXT_PUBLIC_BRAND_NAME=Abada
NEXT_PUBLIC_FIRM_NAME=Balam Legal
# Optional: UUID of the default firm tenant for founder review routing.
# Must match the tenant where firm admins/associates have memberships.
# If unset, the app routes to the tenant with firm memberships (recommended).
DEFAULT_FIRM_TENANT_ID=
# Optional: first firm admin can sign up without an invite (email must match exactly)
FIRM_BOOTSTRAP_ADMIN_EMAIL=

# AI gateway (Anthropic default — swap provider via gateway config later)
ANTHROPIC_API_KEY=
AI_FAST_MODEL=claude-haiku-4-5-20251001
AI_STRONG_MODEL=claude-sonnet-4-20250514

# Payments — Wompi only (Colombia MVP). Live integration pending merchant verification.
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=

# Setup notes:
# 1. In Clerk Dashboard → Supabase integration: enable compatibility (role: authenticated).
# 2. In Supabase Dashboard → Auth → Third-party: add Clerk (domain + JWKS).
# 3. Do NOT create a Clerk JWT template or share Supabase JWT secret with Clerk.
# 4. RLS uses auth.jwt()->>'sub' and membership-based active_tenant_id() — not org_id.
# 5. Clerk Dashboard → User & Authentication → disable Username (or set optional). Required username sends OAuth users to accounts.dev/sign-up for a second signup.
# 6. Clerk Dashboard → Paths → sign-up URL http://localhost:3000/registro, allowed redirects include /sso-callback and /onboarding
# 7. Clerk Dashboard → Attack protection → Bot sign-up protection: disable for custom auth flows.
# 8. Create a Supabase Storage bucket named `data-rooms` for DD uploads (M5).
